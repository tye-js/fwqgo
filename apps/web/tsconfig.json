{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@fwqgo/core/*": ["../../packages/core/*"],
      "@fwqgo/db": ["../../packages/db/index.ts"],
      "@fwqgo/db/*": ["../../packages/db/*"],
      "@/*": ["../../src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../../src/**/*.ts",
    "../../src/**/*.tsx",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx",
    "../../next-env.d.ts",
    "../../.next-web/types/**/*.ts",
    "../../.next-web/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
