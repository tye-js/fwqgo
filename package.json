{
  "name": "fwqgo",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun run build:web && bun run build:cms && bun run verify:apps",
    "build:web": "next build apps/web --turbopack",
    "build:cms": "next build apps/cms --turbopack",
    "check": "bun run verify:repository && bun run lint && bun run typecheck && bun run test && bun run verify:architecture && bun run verify:deploy && bun run verify:migrations && bun run verify:security && bun run verify:cache",
    "deploy:local": "bash scripts/deploy-local-build.sh",
    "healthcheck:prod": "bash scripts/production-healthcheck.sh",
    "verify:apps": "node scripts/verify-app-boundaries.mjs",
    "verify:repository": "node scripts/verify-repository-hygiene.mjs",
    "verify:architecture": "node scripts/verify-architecture.mjs",
    "verify:deploy": "node scripts/verify-deploy-workflow.mjs",
    "verify:migrations": "node scripts/verify-migrations.mjs",
    "verify:security": "tsx scripts/verify-security-boundaries.ts",
    "verify:cache": "tsx scripts/verify-public-cache-boundaries.ts",
    "smoke:built": "node scripts/smoke-built-apps.mjs",
    "smoke:cms": "node scripts/smoke-cms-browser.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "node scripts/migrate-prod.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "links:convert": "tsx scripts/convert-post-links-to-short-slugs.ts",
    "posts:backfill-en-taxonomy": "tsx scripts/backfill-english-taxonomy.ts",
    "offers:backfill-whmcs-prices": "tsx scripts/backfill-whmcs-offer-prices.ts",
    "secrets:migrate": "tsx scripts/migrate-secrets.ts",
    "source:pull": "tsx scripts/pull-source-site-to-ai-drafts.ts",
    "dev": "bun run dev:web",
    "dev:web": "next dev apps/web --turbopack -p 3000",
    "dev:cms": "bun run next dev apps/cms --turbopack -p 3100",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "bun run build && bun run start:web",
    "start": "bun run start:web",
    "start:web": "next start apps/web -p 3000",
    "start:cms": "next start apps/cms -p 3100",
    "test": "set -- tests/*.test.ts; if [ -e \"$1\" ]; then SKIP_ENV_VALIDATION=1 DATABASE_URL=postgresql://test:test@127.0.0.1:5432/fwqgo_test tsx --test \"$@\"; else echo 'No local tests found; skipping private test suite.'; fi",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-navigation-menu": "^1.2.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tiptap/core": "^3.23.5",
    "@tiptap/extension-image": "^3.23.5",
    "@tiptap/extension-link": "^3.23.5",
    "@tiptap/extension-table": "^3.23.5",
    "@tiptap/extension-table-cell": "^3.23.5",
    "@tiptap/extension-table-header": "^3.23.5",
    "@tiptap/extension-table-row": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "postgres": "^3.4.7",
    "puppeteer": "^25.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.76.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "overrides": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3"
  }
}
